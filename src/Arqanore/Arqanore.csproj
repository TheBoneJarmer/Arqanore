<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <PackageId Condition=" '$(OS)' == 'Windows_NT' ">Arqanore.Windows</PackageId>
        <PackageId Condition=" '$(OS)' == 'UNIX' ">Arqanore.Linux</PackageId>
        <Authors>Ruben Labruyere</Authors>
        <Company>Ruben Labruyere</Company>
        <Version>0.4.0</Version>
        <Description>
            Arqanore is a 2D OpenGL framework used to make video games for Linux desktop and Windows desktop. It is built on top of my other library, Arqan, and therefore makes use of the GLFW window and input system. Please makee sure you install all required dependencies!! Read the readme in the repo for more info.
        </Description>
        <Copyright>Copyright 2020 Ruben Labruyere</Copyright>
        <PackageLicenseFile>LICENSE</PackageLicenseFile>
        <RepositoryUrl>https://github.com/TheBoneJarmer/arqanore.git</RepositoryUrl>
        <PackageTags>arqanore, opengl, 2d, framework, glfw, arqan</PackageTags>
        <AssemblyVersion>0.4.0.0</AssemblyVersion>
        <FileVersion>0.4.0.0</FileVersion>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
    </PropertyGroup>

	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

    <ItemGroup>
	    <PackageReference Include="System.Drawing.Common" Version="4.5.1" />
	    <PackageReference Include="Newtonsoft.Json" Version="12.0.2" />
	    <PackageReference Include="Arqan.Linux" Version="0.2.1" Condition=" '$(OS)' == 'UNIX' " />
	    <PackageReference Include="Arqan.Windows" Version="0.2.4" Condition=" '$(OS)' == 'Windows_NT' " />
    </ItemGroup>
	
	<ItemGroup>
        <None Include="../../LICENSE">
          <Pack>True</Pack>
          <PackagePath></PackagePath>
        </None>
  </ItemGroup>
</Project>
